<?xml version="1.0"?>
<robot name="phytium_car">

    <!-- ==================== 基础坐标系 ==================== -->
    <!--
        odom -> base_footprint 由 uart_bridge.py 发布
        base_footprint -> base_link 由 robot_state_publisher 根据本 URDF 发布
    -->
    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <!-- base_link 位于底盘主体中心，离地约 5cm -->
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <!-- ==================== 底盘主体 ==================== -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.24 0.14 0.10"/>
            </geometry>
            <material name="blue">
                <color rgba="0.1 0.1 1.0 0.8"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.24 0.14 0.10"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.5"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia
                ixx="0.01" ixy="0.0" ixz="0.0"
                iyy="0.01" iyz="0.0"
                izz="0.01"/>
        </inertial>
    </link>

    <!-- ==================== 激光雷达 ==================== -->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.04"/>
            </geometry>
            <material name="gray">
                <color rgba="0.5 0.5 0.5 0.8"/>
            </material>
        </visual>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <!-- 雷达安装在底盘中心上方 -->
        <origin xyz="0 0 0.10" rpy="0 0 0"/>
    </joint>

    <!-- ==================== 左驱动轮 ==================== -->
    <link name="left_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder length="0.01" radius="0.024"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 0.8"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder length="0.01" radius="0.024"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia
                ixx="0.00001" ixy="0.0" ixz="0.0"
                iyy="0.00001" iyz="0.0"
                izz="0.00001"/>
        </inertial>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <!-- 轮距 0.128m，所以左轮 y = +0.064m -->
        <origin xyz="0 0.064 -0.024" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="10" velocity="10"/>
    </joint>

    <!-- ==================== 右驱动轮 ==================== -->
    <link name="right_wheel_link">
        <visual>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder length="0.01" radius="0.024"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 0.8"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <cylinder length="0.01" radius="0.024"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.05"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia
                ixx="0.00001" ixy="0.0" ixz="0.0"
                iyy="0.00001" iyz="0.0"
                izz="0.00001"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <!-- 轮距 0.128m，所以右轮 y = -0.064m -->
        <origin xyz="0 -0.064 -0.024" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit effort="10" velocity="10"/>
    </joint>

    <!-- ==================== 中后部万向轮 ==================== -->
    <link name="rear_caster_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 0.8"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.015"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.03"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia
                ixx="0.000005" ixy="0.0" ixz="0.0"
                iyy="0.000005" iyz="0.0"
                izz="0.000005"/>
        </inertial>
    </link>

    <joint name="rear_caster_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_caster_link"/>
        <!--
            中后部万向轮：
            x 为负表示在车体后方。
            如果你的万向轮更靠后，可把 -0.08 改成 -0.10；
            如果更接近中心，可把 -0.08 改成 -0.06。
        -->
        <origin xyz="-0.08 0 -0.035" rpy="0 0 0"/>
    </joint>

    <!-- ==================== IMU (MPU6050) ==================== -->
    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
            <material name="red">
                <color rgba="1.0 0.1 0.1 0.8"/>
            </material>
        </visual>
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <!-- 底盘中心偏上，内部安装 -->
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>

    <!-- ==================== D435i深度相机 ==================== -->
    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.025 0.09 0.025"/>
            </geometry>
            <material name="dark_gray">
                <color rgba="0.2 0.2 0.2 0.9"/>
            </material>
        </visual>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>
        <origin xyz="0.07 0 0.10" rpy="0 0 0"/>
    </joint>

    <!-- 相机光学坐标系：ROS 标准为 z 前、x 右、y 下 -->
    <link name="camera_optical_link"/>

    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_optical_link"/>
        <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>

</robot>
