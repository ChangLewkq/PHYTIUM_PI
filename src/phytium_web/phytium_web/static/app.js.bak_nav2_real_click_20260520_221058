    setText('temp', fmt(sys.temperature_c) + ' ℃');
    setText('disk', fmt(sys.disk_percent) + '%');
    setText('tx', fmt(sys.net_tx_kbps) + ' kbps');
    setText('rx', fmt(sys.net_rx_kbps) + ' kbps');

