    // System
    setText('cpu', fmt(sys.cpu_percent) + '%');
    const cpuBar = $('cpu-bar');
    if (cpuBar) cpuBar.style.width = (sys.cpu_percent || 0) + '%';

    setText('mem', fmt(sys.memory_percent) + '%');
    const memBar = $('mem-bar');
