@app.route('/api/mode', methods=['POST'])
def mode():
    d = request.get_json(force=True) or {}
    requested_mode = str(d.get('mode', 'manual')).strip()

    if requested_mode not in MODE_TO_MUX:
        requested_mode = 'manual'

    mux_mode = MODE_TO_MUX[requested_mode]

    if not bridge:
        return jsonify(ok=False, reason='ros_bridge_not_ready'), 503

    switch_start = time.time()
    _set_transition({
        'active': True,
        'mode': requested_mode,
        'ok': None,
        'duration_sec': 0.0,
        'message': '正在切换',
        'started_at': switch_start,
        'completed_at': None,
    })

    # Clean transition: stop current Web velocity before switching source.
    # This is only zero velocity and does not itself change mux mode.
    bridge.stop()

    task_result = _switch_feature_tasks(requested_mode)

    # Publish mux mode after starting/stopping feature process.
    # For navigation this switches mux to /cmd_vel_nav; Nav2 may still need several seconds to become active.
    mux_result = bridge.publish_mux_mode(mux_mode)

    cache.set_mode(requested_mode)

    # stop mode additionally sends zero velocity after switching.
    if requested_mode == 'stop':
        bridge.stop()

    ready = _measure_mode_ready(requested_mode)
    switch_done = time.time()
    duration = round(switch_done - switch_start, 3)

    ok_all = bool(ready.get('ok', False))
    ready_stage = ready.get('stage', 'ready')
    if ok_all and ready_stage == 'ready':
        message = '切换成功'
    elif ok_all and ready_stage == 'started':
        message = '任务已启动，节点仍在发现/初始化'
    else:
        message = '切换超时/未完全就绪'

    transition_result = {
        'active': False,
        'mode': requested_mode,
        'ok': ok_all,
        'duration_sec': duration,
        'message': message,
        'stage': ready_stage,
        'started_at': switch_start,
        'completed_at': switch_done,
        'ready': ready,
    }
    _set_transition(transition_result)

    return jsonify(
        ok=ok_all,
        mode=requested_mode,
        mux_mode=mux_mode,
        result=mux_result,
        tasks=task_result,
        task_status=tasks.status(),
        transition=transition_result,
    )


@app.route('/api/remote/device', methods=['POST'])
def dev():
    if not remote:
        return jsonify({'ok': False, 'reason': 'remote_monitor_not_ready'})

    d = request.get_json(force=True) or {}
    return jsonify(remote.switch_device(d.get('device', 'gpu')))


def spin():
    rclpy.spin(bridge)


def main():
    global remote, bridge

    rclpy.init()

    n = rclpy.create_node('web_param_loader')
    n.declare_parameter('host', '0.0.0.0')
    n.declare_parameter('port', 5000)
    n.declare_parameter('yolo_receiver_url', 'http://192.168.43.163:8080')

    host = str(n.get_parameter('host').value)
    port = int(n.get_parameter('port').value)
    url = str(n.get_parameter('yolo_receiver_url').value)

    n.destroy_node()

    remote = RemoteMonitor(url)
    bridge = RosBridge(cache)

    threading.Thread(target=spin, daemon=True).start()

    app.run(host=host, port=port, threaded=True)


if __name__ == '__main__':
    main()
