# -*- coding: utf-8 -*-
"""
phytium_web/app.py

Web backend for Phytium ROS2 robot.

Important mode/stop rule:
- /api/stop only publishes zero velocity. It does NOT switch cmd_vel_mux mode.
- /api/mode with mode=stop is the only normal UI action that switches mux to stop.
- Releasing Web control buttons calls /api/stop, so releasing buttons should not leave manual mode.
"""

import os
import re
import subprocess
import threading
import time

import rclpy
from flask import Flask, jsonify, render_template, request

from .remote_monitor import RemoteMonitor
from .ros_bridge import RosBridge
from .state_cache import StateCache
from .system_monitor import SystemMonitor
from .task_manager import TaskManager


app = Flask(__name__, template_folder='templates', static_folder='static')

# ==== WEB CONTROL ORDER GUARD BEGIN ====
# 防止 Web 松开后，旧的 /api/control/hold 请求晚于 /api/stop 到达，
# 导致 /cmd_vel_web 在 0 之后又恢复旧的非零速度。
import time as _web_control_guard_time
from flask import request as _web_control_guard_request
from flask import jsonify as _web_control_guard_jsonify

_web_control_last_stamp_ms = 0
_web_control_drop_unstamped_hold_until = 0.0


def _web_control_get_stamp_ms():
    try:
        data = _web_control_guard_request.get_json(silent=True) or {}
    except Exception:
        data = {}

    # 前端新代码会带 t=Date.now()；seq 作为备用。
    raw = data.get('t', None)
    if raw is None:
        raw = data.get('seq', None)

    try:
        return int(float(raw))
    except Exception:
        return 0


@app.before_request
def _web_control_order_guard():
    global _web_control_last_stamp_ms
    global _web_control_drop_unstamped_hold_until

    path = _web_control_guard_request.path
    if path not in ('/api/control/hold', '/api/control/release', '/api/stop'):
        return None

    now_s = _web_control_guard_time.time()
    stamp_ms = _web_control_get_stamp_ms()

    # release/stop 永远优先允许通过，并记录最新停止时间戳。
    if path in ('/api/control/release', '/api/stop'):
        if stamp_ms <= 0:
            stamp_ms = int(now_s * 1000)

        if stamp_ms > _web_control_last_stamp_ms:
            _web_control_last_stamp_ms = stamp_ms

        # 兼容旧浏览器缓存旧 app.js 的情况：没有 t/seq 的 hold 在 stop 后短时间内丢弃。
        _web_control_drop_unstamped_hold_until = now_s + 0.8
        return None

    # hold 请求：如果它的时间戳早于最近的 stop/release，说明这是旧请求晚到，直接丢弃。
    if path == '/api/control/hold':
        if stamp_ms > 0:
            if stamp_ms < _web_control_last_stamp_ms:
                return _web_control_guard_jsonify({
                    'ok': False,
                    'drop': 'old_hold_after_stop',
                    'stamp_ms': stamp_ms,
                    'last_stamp_ms': _web_control_last_stamp_ms
                })

            if stamp_ms > _web_control_last_stamp_ms:
                _web_control_last_stamp_ms = stamp_ms

            return None

        # 如果 hold 没有时间戳，且刚刚发生过 stop，则认为它不可靠，先丢弃。
        if now_s < _web_control_drop_unstamped_hold_until:
            return _web_control_guard_jsonify({
                'ok': False,
                'drop': 'unstamped_hold_after_stop'
            })

    return None
# ==== WEB CONTROL ORDER GUARD END ====

app.config['SEND_FILE_MAX_AGE_DEFAULT'] = 0

cache = StateCache()
sysmon = SystemMonitor()
remote = None
bridge = None
tasks = TaskManager()
transition_lock = threading.Lock()
last_transition = {
    'active': False,
    'mode': 'manual',
    'ok': True,
    'duration_sec': 0.0,
    'message': '待命',
}




@app.after_request
def add_no_cache_headers(response):
    response.headers['Cache-Control'] = 'no-store, no-cache, must-revalidate, max-age=0'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    return response

MODE_TO_MUX = {
    'manual': 'web',
    'follow': 'follow',
    'mapping': 'web',
    'navigation': 'nav',
    'stop': 'stop',
}


MAP_SAVE_DIR = '/home/user/maps'


def _sanitize_map_name(name):
    """Allow only safe map names for file creation."""
    name = str(name or '').strip()
    if not name:
        name = 'my_map'

    # Drop extension if user typed .yaml/.pgm.
    for suffix in ('.yaml', '.pgm'):
        if name.endswith(suffix):
            name = name[:-len(suffix)]

    name = re.sub(r'[^A-Za-z0-9_\-]', '_', name)
    name = name.strip('_-')

    if not name:
        name = 'my_map'

    return name[:64]


def _run_cmd(args, timeout=20.0):
    try:
        p = subprocess.run(
            args,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
            check=False,
        )
        return {
            'ok': p.returncode == 0,
            'returncode': p.returncode,
            'stdout': (p.stdout or '').strip(),
            'stderr': (p.stderr or '').strip(),
            'cmd': ' '.join(args),
        }
    except subprocess.TimeoutExpired:
        return {
            'ok': False,
            'returncode': -1,
            'stdout': '',
            'stderr': 'timeout',
            'cmd': ' '.join(args),
        }
    except Exception as e:
        return {
            'ok': False,
            'returncode': -2,
            'stdout': '',
            'stderr': str(e),
            'cmd': ' '.join(args),
        }


