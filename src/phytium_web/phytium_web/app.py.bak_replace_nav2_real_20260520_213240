def _strip_heavy_map_data(s):
    """Remove heavy OccupancyGrid data from normal state response.

    /api/state is polled frequently by the dashboard and must stay lightweight,
    otherwise Flask JSON serialization and browser JSON parsing will delay
    /api/cmd control requests.
    """
    m = s.get('map')
    if isinstance(m, dict) and isinstance(m.get('data'), list):
        m = dict(m)
        m['data_count'] = len(m.get('data', []))
        m['data'] = []
        s['map'] = m
    return s


@app.route('/api/state')
def state():
    s = cache.snapshot()
    s = _strip_heavy_map_data(s)
    s['system'] = sysmon.sample()
    s['remote'] = remote.fetch_stats() if remote else {}
    s['tasks'] = tasks.status()
    with transition_lock:
        s['transition'] = dict(last_transition)
    return jsonify(s)


@app.route('/api/radar')
def radar():
