@app.route('/api/map/save', methods=['POST'])
def save_map():
    """Save current SLAM map to /home/user/maps using nav2_map_server map_saver_cli."""
    d = request.get_json(force=True) or {}

    raw_name = d.get('name', 'my_map')
    map_name = _sanitize_map_name(raw_name)

    os.makedirs(MAP_SAVE_DIR, exist_ok=True)

    output_prefix = os.path.join(MAP_SAVE_DIR, map_name)

    # Prevent accidental path traversal after sanitization.
    if not output_prefix.startswith(MAP_SAVE_DIR + os.sep):
        return jsonify(ok=False, reason='invalid_map_path'), 400

    # Save /map using nav2 map_saver_cli.
    result = _run_cmd([
        'ros2',
        'run',
        'nav2_map_server',
        'map_saver_cli',
        '-f',
        output_prefix,
    ], timeout=30.0)

    yaml_path = output_prefix + '.yaml'
    pgm_path = output_prefix + '.pgm'

    saved = os.path.exists(yaml_path) and os.path.exists(pgm_path)

    return jsonify(
        ok=bool(result.get('ok') and saved),
        name=map_name,
        directory=MAP_SAVE_DIR,
        prefix=output_prefix,
        yaml=yaml_path,
        pgm=pgm_path,
        saved=saved,
        result=result,
    )


@app.route('/api/cmd', methods=['POST'])
def cmd():
    """One-shot command endpoint, kept for compatibility."""
    d = request.get_json(force=True) or {}

    if bridge:
        bridge.send_cmd(d.get('linear', 0), d.get('angular', 0))

    return jsonify(ok=True)


@app.route('/api/control/hold', methods=['POST'])
def control_hold():
    """Low-latency hold endpoint.

    Frontend calls this once on pointer/key down.
    RosBridge timer publishes /cmd_vel_web at 20Hz until release.
    """
    d = request.get_json(force=True) or {}

    if not bridge:
        return jsonify(ok=False, reason='ros_bridge_not_ready'), 503

    result = bridge.set_web_hold(d.get('linear', 0), d.get('angular', 0))
    return jsonify(result)


@app.route('/api/control/release', methods=['POST'])
def control_release():
    """Release current Web hold command."""
    if not bridge:
        return jsonify(ok=False, reason='ros_bridge_not_ready'), 503

    result = bridge.release_web_hold()
    return jsonify(result)


@app.route('/api/stop', methods=['POST'])
def stop():
    """
    Soft stop:
    - Only publish zero velocity to /cmd_vel_web.
    - Do NOT change cmd_vel_mux mode.

    Reason:
    The frontend calls /api/stop whenever the user releases a direction button.
    If this endpoint switches mux to stop, manual mode will be lost after every button release.
    """
    if bridge:
        bridge.stop()

    return jsonify(ok=True, action='soft_stop', mode=cache.snapshot().get('mode'))


@app.route('/api/estop', methods=['POST'])
def estop():
    d = request.get_json(force=True) or {}
    en = bool(d.get('enabled', True))

    cache.set_estop(en)

    result = {}

    if bridge:
        bridge.stop()
        result['safety_estop'] = bridge.publish_safety_estop(en)
        result['mux_estop'] = bridge.publish_mux_estop(en)

        # Emergency stop is different from soft stop:
        # it should force mux into stop mode.
        if en:
            result['mux'] = bridge.publish_mux_mode('stop')
            cache.set_mode('stop')

    return jsonify(
        ok=True,
        estop=en,
        **result,
    )




def _set_transition(data):
    with transition_lock:
        last_transition.update(data)


def _measure_mode_ready(requested_mode, timeout_sec=None):
    if timeout_sec is None:
        timeout_sec = {
            'manual': 10.0,
            'stop': 1.0,
            'follow': 30.0,
            'mapping': 30.0,
            'navigation': 45.0,
        }.get(requested_mode, 15.0)

    return tasks.wait_mode_ready(requested_mode, timeout_sec=timeout_sec)


def _switch_feature_tasks(requested_mode):
    """Start/stop feature tasks according to selected mode.

    Base nodes are never stopped here.
    """
    result = {}

    if requested_mode == 'manual':
        result['stopped'] = tasks.stop_all_features()

    elif requested_mode == 'follow':
        result['stopped'] = tasks.stop_many(['mapping', 'navigation'])
        result['vision'] = tasks.start('vision')

    elif requested_mode == 'mapping':
        result['stopped'] = tasks.stop_many(['vision', 'navigation'])
        result['mapping'] = tasks.start('mapping')

    elif requested_mode == 'navigation':
        # Navigation uses its own map_server. Stop SLAM to save CPU.
        result['stopped'] = tasks.stop_many(['vision', 'mapping'])
        result['navigation'] = tasks.start('navigation')

    elif requested_mode == 'stop':
        # STOP only cuts movement output. It does not automatically kill feature tasks.
        # Use manual mode to return to base-only state.
        result['note'] = 'stop_mode_keeps_feature_tasks'

    return result


