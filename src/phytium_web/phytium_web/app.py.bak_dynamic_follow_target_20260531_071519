"""
phytium_web/app.py

Web backend for Phytium ROS2 robot.

Important mode/stop rule:
- /api/stop only publishes zero velocity. It does NOT switch cmd_vel_mux mode.
- /api/mode with mode=stop is the only normal UI action that switches mux to stop.
- Releasing Web control buttons calls /api/stop, so releasing buttons should not leave manual mode.
"""

import os
import re
import subprocess
import threading
import time

import rclpy
from flask import Flask, jsonify, render_template, request

from .remote_monitor import RemoteMonitor
from .ros_bridge import RosBridge
from .state_cache import StateCache
from .system_monitor import SystemMonitor
from .task_manager import TaskManager


app = Flask(__name__, template_folder='templates', static_folder='static')
app.config['SEND_FILE_MAX_AGE_DEFAULT'] = 0

cache = StateCache()
sysmon = SystemMonitor()
remote = None
bridge = None
tasks = TaskManager()
transition_lock = threading.Lock()
last_transition = {
    'active': False,
    'mode': 'manual',
    'ok': True,
    'duration_sec': 0.0,
    'message': '待命',
}




@app.after_request
def add_no_cache_headers(response):
    response.headers['Cache-Control'] = 'no-store, no-cache, must-revalidate, max-age=0'
    response.headers['Pragma'] = 'no-cache'
    response.headers['Expires'] = '0'
    return response

MODE_TO_MUX = {
    'manual': 'web',
    'follow': 'follow',
    'mapping': 'web',
    'navigation': 'nav',
    'stop': 'stop',
}


MAP_SAVE_DIR = '/home/user/maps'


def _sanitize_map_name(name):
    """Allow only safe map names for file creation."""
    name = str(name or '').strip()
    if not name:
        name = 'my_map'

    # Drop extension if user typed .yaml/.pgm.
    for suffix in ('.yaml', '.pgm'):
        if name.endswith(suffix):
            name = name[:-len(suffix)]

    name = re.sub(r'[^A-Za-z0-9_\-]', '_', name)
    name = name.strip('_-')

    if not name:
        name = 'my_map'

    return name[:64]


def _run_cmd(args, timeout=20.0):
    try:
        p = subprocess.run(
            args,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
            check=False,
        )
        return {
            'ok': p.returncode == 0,
            'returncode': p.returncode,
            'stdout': (p.stdout or '').strip(),
            'stderr': (p.stderr or '').strip(),
            'cmd': ' '.join(args),
        }
    except subprocess.TimeoutExpired:
        return {
            'ok': False,
            'returncode': -1,
            'stdout': '',
            'stderr': 'timeout',
            'cmd': ' '.join(args),
        }
    except Exception as e:
        return {
            'ok': False,
            'returncode': -2,
            'stdout': '',
            'stderr': str(e),
            'cmd': ' '.join(args),
        }


