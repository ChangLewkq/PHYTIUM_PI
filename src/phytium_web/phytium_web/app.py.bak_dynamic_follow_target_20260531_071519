def _strip_heavy_map_data(s):
    """Remove heavy OccupancyGrid data from normal state response.

    /api/state is polled frequently by the dashboard and must stay lightweight,
    otherwise Flask JSON serialization and browser JSON parsing will delay
    /api/cmd control requests.
    """
    m = s.get('map')
    if isinstance(m, dict) and isinstance(m.get('data'), list):
        m = dict(m)
        m['data_count'] = len(m.get('data', []))
        m['data'] = []
        s['map'] = m
    return s


@app.route('/api/state')
def state():
    s = cache.snapshot()
    s = _strip_heavy_map_data(s)
    s['system'] = sysmon.sample()
    s['remote'] = remote.fetch_stats() if remote else {}
    s['tasks'] = tasks.status()
    with transition_lock:
        s['transition'] = dict(last_transition)
    return jsonify(s)


@app.route('/api/map')
def map_state():
    """Return full map data separately and at a lower frontend polling rate."""
    s = cache.snapshot()
    m = s.get('map', {})
    return jsonify(m)


@app.route('/api/map/save', methods=['POST'])
def save_map():
    """Save current SLAM map to /home/user/maps using nav2_map_server map_saver_cli."""
    d = request.get_json(force=True) or {}

    raw_name = d.get('name', 'my_map')
    map_name = _sanitize_map_name(raw_name)

    os.makedirs(MAP_SAVE_DIR, exist_ok=True)

    output_prefix = os.path.join(MAP_SAVE_DIR, map_name)

    # Prevent accidental path traversal after sanitization.
    if not output_prefix.startswith(MAP_SAVE_DIR + os.sep):
        return jsonify(ok=False, reason='invalid_map_path'), 400

    # Save /map using nav2 map_saver_cli.
    result = _run_cmd([
        'ros2',
        'run',
        'nav2_map_server',
        'map_saver_cli',
        '-f',
        output_prefix,
    ], timeout=30.0)

    yaml_path = output_prefix + '.yaml'
    pgm_path = output_prefix + '.pgm'

    saved = os.path.exists(yaml_path) and os.path.exists(pgm_path)

    return jsonify(
        ok=bool(result.get('ok') and saved),
        name=map_name,
        directory=MAP_SAVE_DIR,
        prefix=output_prefix,
        yaml=yaml_path,
        pgm=pgm_path,
        saved=saved,
        result=result,
    )



# ==== WEB NAV2 SUBPROCESS API BEGIN ====
def _nav2_read_pose_payload():
    d = request.get_json(force=True) or {}

    try:
        x = float(d.get('x'))
        y = float(d.get('y'))
    except Exception:
        return None, {'ok': False, 'reason': 'bad_x_y', 'data': d}

    try:
        yaw = float(d.get('yaw', 0.0))
    except Exception:
        yaw = 0.0

    return {'x': x, 'y': y, 'yaw': yaw}, None


def _nav2_parse_cmd_result(result):
    import json as _json

    stdout = (result.get('stdout') or '').strip()
    if stdout:
        last = stdout.splitlines()[-1].strip()
        try:
            data = _json.loads(last)
            data['stdout'] = stdout
            data['stderr'] = result.get('stderr', '')
            data['returncode'] = result.get('returncode', 0)
            return data
        except Exception:
            pass

    return result


def _nav2_call_script(script_path, x, y, yaw, timeout=10.0):
    cmd = (
        'source /opt/ros/foxy/setup.bash && '
        'source /home/user/phytium_ws/install/setup.bash && '
        f'python3 {script_path} {float(x):.6f} {float(y):.6f} {float(yaw):.6f}'
    )

    result = _run_cmd(['bash', '-lc', cmd], timeout=timeout)
    return _nav2_parse_cmd_result(result)


@app.route('/api/nav/initial_pose', methods=['POST'])
def nav_initial_pose_real():
    pose, err = _nav2_read_pose_payload()
    if err:
        return jsonify(err), 400

    result = _nav2_call_script(
        '/home/user/phytium_ws/web_nav2_initial_pose_once.py',
        pose['x'],
        pose['y'],
        pose['yaw'],
        timeout=25.0,
    )

    return jsonify(result), (200 if result.get('ok') else 500)


@app.route('/api/nav/goal', methods=['POST'])
def nav_goal_real():
    pose, err = _nav2_read_pose_payload()
    if err:
        return jsonify(err), 400

    result = _nav2_call_script(
        '/home/user/phytium_ws/web_nav2_send_goal_once.py',
        pose['x'],
        pose['y'],
        pose['yaw'],
        timeout=45.0,
    )

    return jsonify(result), (200 if result.get('ok') else 503)
